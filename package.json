{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "ares-agent",
  "description": "The agent that grows with you",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.13",
  "scripts": {
    "dev": "bun run --cwd packages/ares --conditions=browser src/index.ts",
    "lint": "oxlint",
    "typecheck": "bun turbo typecheck",
    "prepare": "husky"
  },
  "workspaces": {
    "packages": [
      "packages/*"
    ],
    "catalog": {
      "@types/bun": "1.3.11",
      "@types/node": "22.13.9",
      "@tsconfig/node22": "22.0.2",
      "@tsconfig/bun": "1.0.9",
      "effect": "4.0.0-beta.48",
      "ai": "6.0.168",
      "@playwright/test": "1.59.1",
      "typescript": "5.8.2",
      "zod": "4.1.8",
      "vite": "7.1.4",
      "@opentui/core": "0.1.99",
      "@opentui/solid": "0.1.99"
    }
  },
  "devDependencies": {
    "@tsconfig/bun": "catalog:",
    "glob": "13.0.5",
    "husky": "9.1.7",
    "oxlint": "1.60.0",
    "oxlint-tsgolint": "0.21.0",
    "prettier": "3.6.2",
    "turbo": "2.8.13"
  },
  "dependencies": {
    "typescript": "catalog:"
  },
  "license": "MIT",
  "prettier": {
    "semi": false,
    "printWidth": 120
  },
  "overrides": {
    "@types/bun": "catalog:",
    "@types/node": "catalog:"
  }
}
